# LFTR Marine Intelligence Globe environment example
# Copy into your deployment environment or installer prompts as needed.

DOMAIN=lftr.biz
HYPERCORN_BIND=127.0.0.1:8000
GOOGLE_MAPS_API_KEY=
AI_FALLBACK=true

# Python / VM tuning
LFTR_MACHINE_PROFILE=e2-vcpu2-16gb-25gbssd
APP_WORKERS=1
MALLOC_ARENA_MAX=2
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1

# GFS source/cache
GFS_CACHE_DIR=.cache/gfs_nomads
GFS_CACHE_TTL_SECONDS=1800
GFS_TIMEOUT_SECONDS=8
GFS_HTTP_TIMEOUT_SECONDS=6
GFS_RETRIES=3
GFS_DECODE_SNAPSHOT_TTL_SECONDS=900

# /gfs/api/frame policy
GFS_FRAME_LIGHTWEIGHT_ONLY=true
GFS_FRAME_HEAVY_WARM=false
GFS_FRAME_CACHE_TTL_SECONDS=120
GFS_VIEWPORT_PAD_FACTOR=1.25

# Tile/cache warm profile
GFS_TILE_READ_WORKERS=6
GFS_TILE_WARM_WORKERS=1
GFS_TILE_WARM_BUILD_LIMIT=8
GFS_ALWAYS_ON_CACHE=true
GFS_ALWAYS_ON_INTERVAL_SEC=180
GFS_ALWAYS_ON_MAX_TILES=96
GFS_CACHE_FRESH_TARGET_SEC=360

# Render/data budgets
GFS_OCEAN_POINTS_MAX=12000
GFS_OCEAN_NCSS_MAX_BOATS=18
GFS_CLOUD_MAX_REGIONS=500
GFS_CLOUD_LIVE_DEDUPE_SECONDS=8
GFS_CLOUD_RETAINED_MAX_AGE_SECONDS=86400
GFS_CLOUDS_FORCE_LIVE_FETCH=true
GFS_OCEAN_POINTS_CACHE_TTL_SECONDS=600
GFS_OCEAN_CACHE_TTL_SECONDS=600
GFS_BAIT_CACHE_TTL_SECONDS=600
GFS_HYCOM_HTTP_TIMEOUT_S=6
GFS_HYCOM_CURL_CONNECT_TIMEOUT_S=4
GFS_HYCOM_CURL_MAX_TIME_S=8

# Ocean/bio sources
GFS_ERDDAP_EKMAN_CSV=https://coastwatch.noaa.gov/erddap/griddap/noaacwBLENDEDNRTcurrentsDaily
GFS_ERDDAP_OISST_CSV=https://www.ncei.noaa.gov/erddap/griddap/ncdc_oisst_v2_avhrr_by_time_zlev_lat_lon.nc
GFS_ERDDAP_CHL_CSV=https://coastwatch.noaa.gov/erddap/griddap/noaacwNPPN20VIIRSDINEOFDaily

LFTR_SEA_GRID_SIZE=48
LFTR_SEA_MAX_DERIVED_CELLS=589824
LFTR_SEA_CRISP_MODE=true
LFTR_SEA_BAIT_LOCAL_SUBGRID=24

# Inland water runtime/first-run policy
LFTR_INLAND_WATER_PROMINENCE_FRACTION=0.25
LFTR_INLAND_WATER_MIN_PROMINENT_FEATURES=8
LFTR_INLAND_WATER_MIN_POLYGON_POINTS=12
LFTR_INLAND_WATER_MIN_LINE_POINTS=8
NHDPLUS_CACHE_DAYS=31
NHD_ARCGIS_TILE_DEG=0.5
NHD_ARCGIS_PAGE_SIZE=100

# Runtime priority warm: lets a new viewport get a few fresh tiles even while a larger warm is running.
GFS_TILE_PRIORITY_WARM_LIMIT=3

# Inland Waters maximum-detail/crisp shoreline mode
NHD_ARCGIS_TILE_DEG=0.25
NHD_ARCGIS_MAX_SOURCE_TILES=24
NHD_ARCGIS_PAGE_SIZE=100
NHD_ARCGIS_MAX_RECORDS_PER_TILE=1800
NHD_MIN_POLYGON_POINTS=3
NHD_MIN_LINE_POINTS=2

# Inland Waters prominence-filtered crisp shoreline mode
NHD_MAX_POLYGONS_PER_TILE=5
NHD_MAX_LINES_PER_TILE=8
NHD_MIN_AREA_KM2_WORLD=0.50
NHD_MIN_AREA_KM2_REGIONAL=0.12
NHD_MIN_AREA_KM2_LOCAL=0.025
NHD_MIN_AREA_KM2_HARBOR=0.005
NHD_MIN_LINE_KM_WORLD=8.0
NHD_MIN_LINE_KM_REGIONAL=3.0
NHD_MIN_LINE_KM_LOCAL=0.8
NHD_MIN_LINE_KM_HARBOR=0.20

# Try HYCOM fallback attempts: all_best surface first, then uv3z depth-0 currents if needed.
GFS_HYCOM_ENABLE_FALLBACK_ATTEMPTS=true

# Ocean truth is HYCOM-only; no OISST SST fallback.
GFS_ALLOW_OISST_SST_FALLBACK=false

GFS_ALLOW_SYNTHETIC_FALLBACK=0

GFS_HYCOM_CACHE_SCHEMA_VERSION=hycom_strict_depth_v1

GFS_MAX_CLOUD_PARTICLES_DESKTOP=5200

GFS_MAX_CLOUD_PARTICLES_MOBILE=2600

GFS_CLOUD_PARTICLE_MULTIPLIER=4.0

GFS_CLOUD_PARTICLE_SIZE_MULTIPLIER=0.25

GFS_BOATER_MIN_OCEAN_POINTS=48

GFS_ADVANCED_BAIT_DETAIL_MULTIPLIER=4

GFS_ADVANCED_BAIT_GRID_CAP=420

GFS_ADVANCED_BAIT_MAX_OUTER_POLYGONS=180

GFS_ADVANCED_BAIT_MAX_INNER_POLYGONS=140

GFS_ADVANCED_BAIT_MAX_CORE_POLYGONS=90

GFS_CLOUD_PARTICLE_MODE=balanced

GFS_CLOUD_PARTICLE_RENDER_STYLE=hybrid_ellipse_clusters

GFS_CLOUD_HYBRID_ELLIPSE_MIN_PER_BODY=10

GFS_CLOUD_HYBRID_ELLIPSE_MAX_PER_BODY=20

GFS_CLOUD_HYBRID_ELLIPSE_MICRO_MIN=9

GFS_CLOUD_HYBRID_ELLIPSE_MICRO_MAX=22

GFS_CLOUD_HYBRID_CLUSTER_SCALE=1.0

GFS_BOAT_MIN_OCEAN_POINTS=48

GFS_BOAT_COUNT_MAX=10

GFS_VIEWPORT_BOAT_COUNT=10

GFS_OCEAN_ANALYSIS_MODE=coastal_refine

GFS_OCEAN_POINTS_DATA_MAX=12000

GFS_OCEAN_POINTS_RENDER_MAX=1200

GFS_HYCOM_WORLD_STRIDE=2

GFS_HYCOM_REGIONAL_STRIDE=1

GFS_HYCOM_COASTAL_STRIDE=2

GFS_HYCOM_HARBOR_STRIDE=1

GFS_HYCOM_MAX_PROVIDER_STRIDE=2

GFS_BOAT_MODEL_SCALE=1.0

GFS_BOAT_MODEL_SCALE_MAX=1.0

GFS_BOAT_MODEL_SCALE_GROWTH=0.0

GFS_BOAT_WATER_ALTITUDE_M=0.25

GFS_BOAT_GLYPH_ALTITUDE_M=7.5

GFS_BOAT_UNDERGLOW_ALTITUDE_M=1.2

GFS_BOAT_MODEL_YAW_OFFSET_DEG=0

GFS_BOAT_MODEL_TILT_DEG=0

GFS_BOAT_MODEL_ROLL_DEG=0

GFS_HYCOM_TIMEOUT_SAFE_STRIDE=1

GFS_HYCOM_DETAIL_PROFILE=aggressive_native_regional_world2

# Viewport/tile data TTLs and browser render dedupe. Provider fetches should stay
# within the active viewport/tile plan; these defaults keep rendered layers stable
# while cache refreshes happen in the background.
GFS_WEATHER_TTL_SECONDS=900
GFS_CURRENT_TTL_SECONDS=900
GFS_CLOUD_DATA_TTL_SECONDS=600
GFS_RAIN_TTL_SECONDS=600
GFS_SST_TTL_SECONDS=1800
GFS_BAIT_TTL_SECONDS=900
GFS_BOATS_TTL_SECONDS=300
GFS_FISH_TTL_SECONDS=1800
GFS_JETSTREAM_TTL_SECONDS=900
GFS_DIAG_VIEWPORT_TILE_GRID=6
GFS_CAMERA_STEADY_DEBOUNCE_MS=800
GFS_CLOUD_RENDER_TTL_MS=600000
GFS_RAIN_RENDER_TTL_MS=300000
GFS_BAIT_RENDER_TTL_MS=900000
GFS_BOATS_RENDER_TTL_MS=300000
GFS_CURRENT_RENDER_TTL_MS=600000
GFS_JETSTREAM_DATA_TTL_MS=900000
GFS_FISH_RENDER_TTL_MS=1800000

# Lightning is rendered as short-lived event particles only. Cached/stale GLM
# flashes older than this are filtered out server-side and fade/remove client-side.
GFS_GLM_FLASH_TTL_SECONDS=600
GFS_LIGHTNING_FADE_OUT_MS=2200
# Keep false by default: in-process NetCDF/HDF GLM warm can destabilize Hypercorn.
# Cached lightning still renders; run live GLM warm only after provider isolation.
GFS_ENABLE_GLM_DEFERRED_WARM=false

# Scene-tier refresh budgets. Pills stay ON, but refreshes are cache-first and capped.
GFS_WORLD_OCEAN_REFRESH_MAX_TILES=8
GFS_REGIONAL_OCEAN_REFRESH_MAX_TILES=24
GFS_COASTAL_OCEAN_REFRESH_MAX_TILES=64
GFS_HARBOR_OCEAN_REFRESH_MAX_TILES=64
GFS_WORLD_WEATHER_REFRESH_MAX_TILES=16
GFS_REGIONAL_WEATHER_REFRESH_MAX_TILES=48
GFS_COASTAL_WEATHER_REFRESH_MAX_TILES=64
GFS_HARBOR_WEATHER_REFRESH_MAX_TILES=64
GFS_TILE_WARM_BUILD_LIMIT=8
GFS_ALWAYS_ON_MAX_TILES=16
INLAND_WATER_CACHE_RETENTION_DAYS=60

# Second-pass runtime orchestration guardrails.
# These are hard provider-tile caps used after a large visible bbox is split into
# provider-safe 1-degree HYCOM/RTOFS tiles. World boot should never schedule
# hundreds of provider tiles just because a pill is ON.
GFS_LOCAL_OCEAN_REFRESH_MAX_TILES=64
GFS_OCEAN_TILE_REFRESH_COOLDOWN_MS=120000
GFS_OCEAN_PROVIDER_MAX_SYNC_TILES=16

# Browser/read route policy: world-tier inland water reads durable cache only.
# Use /gfs/api/inland-water/build-cache?explicit=1 or admin=1 only for intentional admin builds.
INLAND_WATER_WORLD_BROWSER_BUILD_DISABLED=1

# Lightweight global lake overview fallback. Real NHD/ArcGIS runtime tiles still win;
# this only prevents blank world zoom if static/data/nhdplus_hr/tiles/index.json is missing.
LFTR_GLOBAL_LAKE_OVERVIEW_ENABLED=0
# Static/placeholder lake fallback is disabled by default. World/global lakes come from real NHD vectors only.
LFTR_GLOBAL_LAKE_OVERVIEW_VERTICES=40
LFTR_GLOBAL_LAKE_OVERVIEW_MAX_LAKES=96
LFTR_GLOBAL_LAKE_OVERVIEW_MIN_AREA_KM2=18
